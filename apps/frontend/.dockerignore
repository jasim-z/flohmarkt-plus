# Ignore config files that cause restarts
next.config.ts
next.config.js
next.config.mjs

# Ignore other files that might cause issues
.git
.gitignore
README.md
.env.local
.env.development.local
.env.test.local
.env.production.local

# Ignore build artifacts
.next
out
dist

# Ignore logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Ignore OS files
.DS_Store
Thumbs.db